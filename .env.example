# StudyStation - Firebase Environment Variables
# Copy this file to .env.local and fill in your values

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your_project-default-rtdb.asia-southeast1.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Gemini AI Keys — CHỈ DÙNG CHO LOCAL DEV
# Ở production, keys được set trực tiếp trên Cloudflare Pages
# (Settings > Environment Variables) KHÔNG có prefix VITE_
# Tên biến trên Cloudflare: GEMINI_API_KEY_1, GEMINI_API_KEY_2, GEMINI_API_KEY_3
VITE_GEMINI_API_KEY_1=your_gemini_key_1
VITE_GEMINI_API_KEY_2=your_gemini_key_2
VITE_GEMINI_API_KEY_3=your_gemini_key_3
